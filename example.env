# OpenClaw Easy — example environment file
# Copy the lines you need into the service env panel in Easypanel.

# ── Image ──────────────────────────────────────────────────────────────────
# Pin the image tag here. Bump this to upgrade.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.6.6

# ── Required ───────────────────────────────────────────────────────────────
# Auth token for the gateway. Generate with: openssl rand -hex 32
# Never leave this empty or use an example value — OpenClaw refuses to start.
OPENCLAW_GATEWAY_TOKEN=

# ── Reverse proxy / CORS ───────────────────────────────────────────────────
# Your public domain (used for CORS on the Control UI).
# Comma-separated if you have more than one.
OPENCLAW_ALLOWED_ORIGINS=https://openclaw.example.com

# Trusted reverse-proxy IPs/CIDRs — comma-separated, no spaces.
# The default covers Easypanel's internal network (10.11.0.0/16).
OPENCLAW_TRUSTED_PROXIES=127.0.0.1,10.11.0.0/16,::1

# Skip per-browser device pairing. Default (empty) keeps OpenClaw's secure model
# where each new browser must be approved via `openclaw devices approve`.
# Set to 1 so the gateway token alone grants access — handy for a single user,
# but any browser with the token gets in (no per-device identity). Trusted nets only.
OPENCLAW_DISABLE_DEVICE_AUTH=

# ── Custom / private model provider (optional) ─────────────────────────────
# Set these to connect a self-hosted OpenAI-compatible endpoint
# (e.g. vLLM, Ollama, dgx1, LM Studio).
# Leave blank to use a built-in cloud provider via its key below instead.
OPENCLAW_BASE_URL=https://your-model-server.example.com/v1
OPENCLAW_API_KEY=
OPENCLAW_MODEL=your-model-name
# Provider name shown inside OpenClaw (any identifier you like)
OPENCLAW_PROVIDER=custom

# ── Default model selection (redeploy-safe) ────────────────────────────────
# Picks the agent's default model and is written into openclaw.json on every
# start, so it survives redeploys (unlike picking a model in the Control UI,
# which gets overwritten). Use "<provider>/<model>".
# Most built-in providers (openai, anthropic, openrouter, …) are activated by
# their *_API_KEY env var alone — no base URL needed.
OPENCLAW_MODEL_PRIMARY=zai/glm-5.2
# Comma-separated fallback list, tried in order if the primary fails.
OPENCLAW_MODEL_FALLBACKS=openrouter/minimax-m3

# Override a built-in provider's endpoint: OPENCLAW_<PROVIDER>_BASE_URL.
# z.ai serves a general endpoint (.../api/paas/v4, default model glm-5.1) and a
# coding-plan endpoint (.../api/coding/paas/v4, default model glm-5.2). The
# built-in zai provider defaults to the *general* one, so to use glm-5.2 on the
# coding plan you MUST point it at the coding endpoint:
OPENCLAW_ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# ── Cloud provider keys (optional) ─────────────────────────────────────────
# Set any of these to activate the matching built-in provider.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# Z.ai (GLM). ZAI_API_KEY is the canonical name OpenClaw reads;
# Z_AI_API_KEY is only a legacy alias — set just ZAI_API_KEY.
# ZAI_API_KEY=...
#
# NOTE: every variable you add to the Easypanel env panel is now passed
# through to the container at runtime (via env_file), so the agent and
# OpenClaw can read any key/setting you add here without editing the compose.

# ── Image pull policy ──────────────────────────────────────────────────────
# always (default): pull latest matching tag on every Redeploy
# missing:          use cached image, skip pull (freeze the current version)
PULL_POLICY=always

# ── Port ───────────────────────────────────────────────────────────────────
# Host port the gateway is published on.
# When using a Traefik domain in Easypanel you can leave this as-is.
OPENCLAW_PORT=18789
